# =============================================
# AskGita.net — Environment Variables
# =============================================
# Copy this file to .env and fill in real values.
# On Vercel, add these in the project Settings → Environment Variables.

# PostgreSQL connection string
# Recommended: Neon (https://neon.tech) — free tier, Vercel partner
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Anthropic API key — get from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-...

# Session secret — generate with: openssl rand -hex 32
SESSION_SECRET=replace-with-a-random-64-character-hex-string
