# =============================================================================
# Bhagavad Gita App — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# For Vercel: add these in the Vercel Dashboard → Project → Settings → Env Vars
# =============================================================================

# PostgreSQL database connection string (required)
# Vercel: use Neon, Supabase, or any PostgreSQL provider
DATABASE_URL=postgresql://user:password@host:5432/dbname

# OpenAI API (via Replit AI Integration — or direct OpenAI key for Vercel)
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1
AI_INTEGRATIONS_OPENAI_API_KEY=sk-...

# Session secret — generate with: openssl rand -base64 32
SESSION_SECRET=change-me-to-a-random-string-at-least-32-chars

# Node environment
NODE_ENV=production

# Frontend build (set automatically by Vercel build command in vercel.json)
PORT=3000
BASE_PATH=/
