# =============================================================================
# Bhagavad Gita App — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# For Vercel: add these in the Vercel Dashboard → Project → Settings → Env Vars
# =============================================================================

# PostgreSQL database connection string (required)
# Vercel: use Neon, Supabase, or any PostgreSQL provider
DATABASE_URL=postgresql://user:password@host:5432/dbname

# OpenAI API
# On Replit: these are set automatically via Replit AI Integrations
# On Vercel: set AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1
#            and AI_INTEGRATIONS_OPENAI_API_KEY to your real OpenAI key (sk-...)
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1
AI_INTEGRATIONS_OPENAI_API_KEY=sk-...

# Session secret — generate with: openssl rand -base64 32
SESSION_SECRET=change-me-to-a-random-string-at-least-32-chars

# Node environment
NODE_ENV=production

# Frontend build (set automatically by Vercel build command in vercel.json)
PORT=3000
BASE_PATH=/

# =============================================================================
# VITE_API_BASE_URL — only needed when frontend & API are on DIFFERENT servers
# =============================================================================
# Leave this unset on Replit (frontend + API share the same proxy).
# On Vercel: if you deploy the Express API separately (Railway, Render, Replit),
# set this to its URL so the frontend can reach it.
# Example: VITE_API_BASE_URL=https://api.askgita.net
# VITE_API_BASE_URL=
